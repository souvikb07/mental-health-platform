{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RiskClassification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "riskLevel",
    "categories",
    "requiresCrisisResponse",
    "reason",
    "resourceTopics"
  ],
  "properties": {
    "riskLevel": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "imminent"
      ]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "self_harm",
          "harm_to_others",
          "abuse_or_domestic_violence",
          "psychosis_or_mania_signal",
          "substance_use",
          "minor_safety",
          "medical_emergency",
          "eating_disorder_signal",
          "none"
        ]
      }
    },
    "requiresCrisisResponse": {
      "type": "boolean"
    },
    "reason": {
      "type": "string"
    },
    "resourceTopics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
