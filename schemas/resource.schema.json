{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resource",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "country",
    "topic",
    "category",
    "name",
    "description",
    "priority"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "phone": {
      "type": [
        "string",
        "null"
      ]
    },
    "priority": {
      "type": "integer"
    },
    "verifiedAt": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
