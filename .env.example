# MindBridge environment template
#
# This file is committed as documentation only.
# Do not put real secrets in this file.
# Copy to `.env.local` for local development and keep `.env.local` untracked.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser and must never contain secrets.

# Public browser-exposed values. Placeholders only.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MindBridge
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_me_public_publishable_key

# Server-only values. Never expose these in client components or NEXT_PUBLIC_ variables.
OPENAI_API_KEY=replace_me_server_only
SUPABASE_URL=replace_me_server_only_project_url
SUPABASE_SECRET_KEY=replace_me_server_only_secret_key
# Legacy fallback accepted temporarily: SUPABASE_SERVICE_ROLE_KEY
MIND_BRIDGE_DATA_ENCRYPTION_KEY_V1=replace_me_base64_32_byte_key_server_only
MIND_BRIDGE_RATE_LIMIT_HMAC_KEY=replace_me_base64_32_byte_key_server_only
# Production trusted direct-ingress policy for IP rate limits: vercel
MIND_BRIDGE_TRUSTED_IP_SOURCE=vercel
STRIPE_SECRET_KEY=replace_me_server_only
STRIPE_WEBHOOK_SECRET=replace_me_server_only

# Optional server-side configuration placeholders.
MIND_BRIDGE_DATA_MODE=transient
OPENAI_MODEL=replace_me_server_selected_model
OPENAI_TRIAGE_MODEL=replace_me_server_selected_triage_model
OPENAI_CONTEXT_INTAKE_MODEL=replace_me_server_selected_context_intake_model
OPENAI_RISK_MODEL=replace_me_server_selected_risk_model
OPENAI_CLARITY_MODEL=replace_me_server_selected_clarity_model
DEFAULT_RESOURCE_COUNTRY=India
ENABLE_ANALYTICS=false
VERCEL_PROJECT_PRODUCTION_URL=replace_me_deployment_host
